# ===========================================
# Deadswitch Environment Variables
# ===========================================
# Copy to .env and fill in values. NEVER commit .env!

# --- Solana ---
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_PROGRAM_ID=DeadSw1tch1111111111111111111111111111111111

# --- Helius ---
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@host/deadswitch?sslmode=require

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@deadswitch.xyz

# --- Heartbeat Authority (backend keypair, base58-encoded secret key) ---
# WARNING: This is a SECRET KEY. Never expose with NEXT_PUBLIC_ prefix.
HEARTBEAT_AUTHORITY_SECRET_KEY=

# --- Crank Bot ---
CRANK_WALLET_SECRET_KEY=
CRANK_INTERVAL_MS=60000
CRANK_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_SPL_TOKENS=true
NEXT_PUBLIC_ENABLE_EMAIL_ALERTS=true
ENABLE_CRANK_BOT=true
