{
  "name": "deadswitch-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Onchain inheritance & dead man's switch protocol on Solana",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:sdk": "npm run build --workspace=@deadswitch/sdk",
    "build:app": "npm run build --workspace=@deadswitch/app",
    "build:crank": "npm run build --workspace=@deadswitch/crank",
    "dev": "npm run dev --workspace=@deadswitch/app",
    "test:anchor": "cd packages/program && anchor test",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
